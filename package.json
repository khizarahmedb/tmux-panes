{
  "name": "tmux-panes",
  "version": "0.1.0",
  "description": "A beautiful TUI dashboard for monitoring tmux panes with AI agent detection",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "tmux-panes": "./bin/tmux-panes"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --compile --outfile bin/tmux-panes-bin",
    "test": "bun test tests/",
    "test:watch": "bun test --watch tests/",
    "test:coverage": "bun test --coverage tests/",
    "test:all": "bun run scripts/test-all.ts",
    "lint": "tsc --noEmit",
    "validate": "bun run lint && bun run test"
  },
  "keywords": ["tmux", "tui", "terminal", "monitor", "dashboard", "ai-agents", "opentui"],
  "license": "MIT",
  "author": "Khizar Ahmed",
  "repository": {
    "type": "git",
    "url": "https://github.com/khizarahmedb/tmux-panes"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@opentui/core": "^0.1.97"
  }
}
